    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.0",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.9.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.1"
